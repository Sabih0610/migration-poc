{
  "name": "trg_daily_sales",
  "properties": {
    "type": "ScheduleTrigger",
    "typeProperties": {
      "recurrence": {
        "frequency": "Day",
        "interval": 1,
        "startTime": "2024-01-01T02:00:00Z",
        "timeZone": "UTC"
      }
    },
    "pipelines": [
      {
        "pipelineReference": {
          "referenceName": "pl_sales_processing_legacy",
          "type": "PipelineReference"
        },
        "parameters": {
          "RunDate": "@trigger().scheduledTime"
        }
      }
    ],
    "description": "Daily trigger at 2:00 AM UTC for sales processing pipeline."
  }
}
